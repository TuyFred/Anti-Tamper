# ============================================================
# Smart Box Delivery — Server (Render / local)
# Copier vers server/.env pour le dev local
# Production : deploy/render.env ou dashboard Render
# ============================================================

NODE_ENV=development

# Supabase (Project Settings → API)
SUPABASE_URL=https://bhyncpphxbpdqzluwoqa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend Vercel (CORS — sans slash final)
CLIENT_URL=http://localhost:5173
# Production: CLIENT_URL=https://anti-tamper.vercel.app

# URL publique de l’API (uploads vidéo promo, liens absolus)
PUBLIC_BASE_URL=http://localhost:3001
# Production: PUBLIC_BASE_URL=https://anti-tamper.onrender.com

# MQTT (public broker ou le vôtre — identique au firmware ESP32)
MQTT_BROKER_URL=mqtt://test.mosquitto.org:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Email alerts — Brevo SMTP (production)
EMAIL_ENABLED=false
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-login-email
SMTP_PASS=your-brevo-smtp-key-xsmtpsib
SMTP_FROM=alerts@your-verified-domain.com

# Livraison / paiements (optionnel)
DELIVERY_CURRENCY=RWF
MOMO_PAY_NUMBER=+250 791 691 817
MOMO_PAY_NAME=Smart Box Delivery
WHATSAPP_SUPPORT=250791691817
WHATSAPP_DISPLAY=+250 791 691 817

MAX_PROMO_VIDEO_MB=200

# Render injecte PORT automatiquement — ne pas le définir en production
