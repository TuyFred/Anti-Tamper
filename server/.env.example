# ============================================================
# Smart Box Delivery — Server (Render)
# Copy to Render → Environment variables
# ============================================================

NODE_ENV=production

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your Vercel frontend URL (no trailing slash)
CLIENT_URL=https://your-app.vercel.app

# Optional: extra origins (comma-separated) e.g. custom domain
# CLIENT_URLS=https://www.yourdomain.com,https://yourdomain.com

# Render service URL (Settings → copy URL, no trailing slash)
PUBLIC_BASE_URL=https://smart-box-api.onrender.com

# MQTT (public broker or your own)
MQTT_BROKER_URL=mqtt://test.mosquitto.org:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Email alerts (optional)
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Delivery / payments (optional overrides)
DELIVERY_CURRENCY=RWF
MOMO_PAY_NUMBER=+250 791 691 817
MOMO_PAY_NAME=Smart Box Delivery
WHATSAPP_SUPPORT=250791691817
WHATSAPP_DISPLAY=+250 791 691 817

# Promo video upload limit (MB)
MAX_PROMO_VIDEO_MB=200

# Render sets PORT automatically — do not hardcode in production
