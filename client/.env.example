# ============================================================
# Smart Box Delivery — Client (Vercel)
# Add in Vercel → Project → Settings → Environment Variables
# ============================================================

# Supabase (Project Settings → API — use anon key only)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Render backend URL (no trailing slash)
VITE_API_URL=https://smart-box-api.onrender.com
VITE_SOCKET_URL=https://smart-box-api.onrender.com

# WhatsApp business line (optional)
VITE_WHATSAPP_NUMBER=250791691817
VITE_WHATSAPP_DISPLAY=+250 791 691 817
